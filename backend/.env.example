# КУДРИ backend — пример переменных окружения.
# Скопировать в backend/.env на сервере и заполнить реальными значениями.
# backend/.env в git не попадает (см. .gitignore).

# Основной порт Express API (проксируется nginx с api.elenadortman.store)
PORT=3001

# Google Gemini — OCR и анализ INCI (основной провайдер)
GEMINI_API_KEY=

# OpenAI-совместимый API — fallback на случай квоты/сбоя Gemini.
# Оставить пустым OPENAI_API_KEY — fallback отключён.
# Поддерживается любой провайдер с OpenAI Chat Completions API:
#   - OpenAI:      OPENAI_BASE_URL=https://api.openai.com/v1        OPENAI_MODEL=gpt-4o-mini
#   - DeepSeek:    OPENAI_BASE_URL=https://api.deepseek.com/v1      OPENAI_MODEL=deepseek-chat
#   - OpenRouter:  OPENAI_BASE_URL=https://openrouter.ai/api/v1     OPENAI_MODEL=openai/gpt-4o-mini
# Для РФ: можно направить OPENAI_BASE_URL на Cloudflare Worker-прокси.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Telegram-бот @kudri_lena_bot
TG_BOT_TOKEN=

# ID администратора (Telegram). Захардкожен в коде, но продублирован здесь для прозрачности.
ADMIN_TG_ID=845707896

# Путь к SQLite-базе (относительно корня проекта)
DB_PATH=./data/kudri.db
